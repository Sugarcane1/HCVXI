# Build outputs
build/
!webview2_sdk/**/build/
out/
*.exe
!webview2_sdk/**/*.exe
*.obj
*.pdb
*.ilk
*.exp

# Libraries (except WebView2 SDK)
*.lib
!webview2_sdk/**/*.lib

# DLLs (except WebView2 SDK)
*.dll
!webview2_sdk/**/*.dll

# IDE
.vs/
*.slnx.sqlite
*.user
.vscode/

# Dependencies (runtime binaries, should be downloaded at install time)
WebView2Runtime/
*.cab

# CrystalDiskInfo bundled binary
CrystalDiskInfo*/

# Portable package
HardwareDetect-Portable/

# Logs
logs/
*.log

# Config (user's local overrides)
config.local.json

# OS files
.DS_Store
Thumbs.db

# Archive files
*.zip
!webview2_sdk/**/*.zip
*.7z
*.rar
